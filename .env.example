# Локальные параметры PostgreSQL для Docker Compose.
# Скопируйте файл в .env и при необходимости измените значения.
POSTGRES_DB=neuro_simulator
POSTGRES_USER=neuro_simulator
POSTGRES_PASSWORD=neuro_simulator_dev
POSTGRES_PORT=5432

# Будущая интеграция FastAPI с PostgreSQL будет использовать эту строку.
# Если меняете параметры выше, синхронно обновите DATABASE_URL.
DATABASE_URL=postgresql+psycopg://neuro_simulator:neuro_simulator_dev@127.0.0.1:5432/neuro_simulator

# Локальные демонстрационные аккаунты. Измените пароли в созданном .env.
DEMO_OBSERVER_PASSWORD=ObserverDemo2026!
DEMO_USER_PASSWORD=UserDemo2026!
DEMO_ADMIN_PASSWORD=AdminDemo2026!

# Для локального HTTP cookie Secure должен быть выключен.
SESSION_COOKIE_SECURE=false
SESSION_TTL_SECONDS=28800
APP_PORT=8000
